{
  "name": "@vsa/visualizer",
  "version": "0.11.0",
  "description": "Generate architecture diagrams from VSA projects",
  "main": "dist/index.js",
  "bin": {
    "vsa-visualizer": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "npm run type-check && npm run lint && npm run format:check && npm test",
    "check-fix": "npm run type-check && npm run lint:fix && npm run format && npm test"
  },
  "keywords": [
    "vsa",
    "architecture",
    "diagrams",
    "mermaid",
    "c4",
    "event-sourcing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
