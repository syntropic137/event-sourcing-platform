{
  "name": "event-sourcing-platform",
  "version": "0.12.0",
  "private": true,
  "workspaces": [
    "event-store/sdks/sdk-ts",
    "event-sourcing/typescript",
    "examples/*-ts",
    "vsa/vsa-visualizer"
  ],
  "scripts": {
    "build": "turbo run build --filter='!docs-site'",
    "build:all": "turbo run build",
    "build:docs": "turbo run build --filter=docs-site",
    "test": "turbo run test",
    "lint": "turbo run lint --continue || true",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean || true"
  },
  "devDependencies": {
    "turbo": "^2.9.7"
  },
  "pnpm": {
    "overrides": {
      "follow-redirects": ">=1.16.0",
      "protobufjs": ">=7.5.5",
      "dompurify": ">=3.4.0"
    }
  },
  "packageManager": "pnpm@10.20.0"
}
